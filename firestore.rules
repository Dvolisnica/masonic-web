rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Korisnički profili: čitljivi svima prijavljenim (leaderboard, profili),
    // a piše ih isključivo vlasnik.
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && validUser(request.resource.data);
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && validUser(request.resource.data)
                    // ELO se može mijenjati najviše +/- 100 po upisu (anti-cheat ublažavanje)
                    && (request.resource.data.elo - resource.data.elo) <= 100
                    && (resource.data.elo - request.resource.data.elo) <= 100;
      allow delete: if false;
    }

    // Arhiva završenih partija — upisuje bilo koji učesnik, immutable nakon upisa.
    match /matches/{matchId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.playerUids;
      allow update, delete: if false;
    }

    function validUser(d) {
      return d.name is string && d.name.size() <= 50
          && d.elo is number && d.elo >= 0 && d.elo <= 4000
          && d.games is number && d.games >= 0
          && d.wins is number && d.wins >= 0
          && d.losses is number && d.losses >= 0;
    }
  }
}
